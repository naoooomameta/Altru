# Microsoft Clarity Data Export API token.
# Generate from: Clarity dashboard > Settings > Data Export > Generate new API token
CLARITY_API_TOKEN=

# Number of days to fetch (1-3). Defaults to 1.
CLARITY_NUM_DAYS=1

# Resend API key for the daily Clarity email digest.
# Generate from: https://resend.com/api-keys
RESEND_API_KEY=

# Mail settings for the Clarity daily digest (optional; defaults shown).
MAIL_FROM=clarity@altru.jp
MAIL_TO=altru.inc.jp@gmail.com
